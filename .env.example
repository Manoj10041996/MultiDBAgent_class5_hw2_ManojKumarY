# ── LLM (Groq API) ────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=openai/gpt-oss-120b
AGENT_MAX_ITERATIONS=5

# ── Embeddings (local SentenceTransformers — no API key needed) ───────────
# Model is downloaded automatically on first run from Hugging Face
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Postgres / Supabase ───────────────────────────────────────────────────
POSTGRES_URL=postgresql://stockpulse:stockpulse_dev@localhost:5432/stockpulse

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGO_URL=mongodb://stockpulse:stockpulse_dev@localhost:27017/stockpulse?authSource=admin
MONGO_DB=stockpulse
